---
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';

import customBoatExterior from '@images/boat.jpg';
import customBoatOnWater from '@images/boat_3.jpg';
import repairWork from '@images/welds_3.jpg';
import ultraDeckCockpit from '@images/marine_deck6.jpg';
import ultraDeckRearDeck from '@images/marine_deck5.jpg';
import { SITE } from '@data/constants';

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: 'Custom Boat Builds',
    subTitle:
      'We build custom aluminum boats for the way you actually use them. From compact skiffs to larger offshore hulls, every build is laid out for strength, function, and long-term durability. We can help shape the hull, deck layout, storage, fuel system, and working details so the finished boat fits your fishing, work, or utility needs instead of forcing you into a generic setup.',
    single: false,
    imgOne: customBoatExterior,
    imgOneAlt: 'Custom aluminum boat on trailer outside the shop.',
    imgTwo: customBoatOnWater,
    imgTwoAlt: 'Custom aluminum boat on the water.',
    btnExists: true,
    btnTitle: 'Request a Quote',
    btnURL: '/contact',
  },
  {
    isRightSection: false,
    title: 'Boat Repairs and Fabricated Parts',
    subTitle:
      'Repairs are a major part of what we do. We handle cracked welds, structural damage, transom repairs, deck work, hatches, brackets, one-off fabricated parts, and made-to-fit fuel tanks. Whether the job is getting an older boat back in service or fixing damage before it gets worse, the goal is practical repair work that makes the boat solid, safe, and ready to run again.',
    img: repairWork,
    imgAlt: 'Marine welding and boat repair work.',
    btnExists: true,
    btnTitle: 'Talk About Your Repair',
    btnURL: '/contact',
  },
  {
    isRightSection: true,
    title: 'UltraDeck Marine Flooring',
    subTitle:
      'UltraDeck marine flooring is a clean upgrade for traction, comfort, and finished appearance. We install it for fishing boats, workboats, and family boats that need a tougher and better-looking deck surface. It is a strong option when you want better footing, easier cleanup, and a more complete finished feel without turning the boat into something delicate.',
    single: false,
    imgOne: ultraDeckCockpit,
    imgOneAlt: 'Boat interior with custom UltraDeck marine flooring.',
    imgTwo: ultraDeckRearDeck,
    imgTwoAlt: 'Boat rear deck finished with UltraDeck marine flooring.',
    btnExists: true,
    btnTitle: 'Ask About UltraDeck',
    btnURL: '/contact',
  },
];

const pageTitle = `Services | ${SITE.title}`;
const metaDescription =
  'Explore Fineline Jetboats services: custom aluminum boat builds, structural boat repairs and fabricated marine parts, plus UltraDeck marine flooring installation.';
const ogTitle = 'Custom Boat Builds, Repairs, and UltraDeck | Fineline Jetboats';
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://screwfast.uk/services',
    url: 'https://screwfast.uk/services',
    name: 'Fineline Jetboats Services',
    description: metaDescription,
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://screwfast.uk',
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: 'en-US',
  }}
>
  <MainSection
    title="Marine Fabrication Services Built Around Real Boats"
    subTitle="Fineline Jetboats focuses on three core services: custom aluminum boat builds, structural repairs and fabricated parts, and UltraDeck marine flooring. Whether you are bringing us a small skiff, a workboat, or a larger offshore project, the work is built around function, durability, and how the boat will actually be used."
    btnExists={true}
    btnTitle="Request a Quote"
    btnURL="/contact"
  />

  {
    articles.map(article =>
      article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      )
    )
  }

  <FeaturesStats
    title="What We Work On"
    subTitle="The shop is built around practical marine fabrication work: custom layouts, repair-driven welding, made-to-fit parts, and deck upgrades that hold up on the water."
    mainStatTitle="3"
    mainStatSubTitle="core services that cover full builds, repair work, and finished deck upgrades"
    stats={[
      {
        stat: 'Skiffs to 40 ft',
        description: 'Custom aluminum projects for small utility boats through larger offshore builds',
      },
      {
        stat: 'Repairs + parts',
        description: 'Structural repair work, brackets, hatches, transoms, and fuel tanks',
      },
      {
        stat: 'UltraDeck',
        description: 'Marine flooring installed for better traction, comfort, and finish',
      },
    ]}
  />
</MainLayout>
