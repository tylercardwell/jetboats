---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro';
import ClientsSection from '@components/sections/landing/ClientsSection.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import FeaturesNavs from '@components/sections/features/FeaturesNavs.astro';
import TestimonialsSection from '@components/sections/testimonials/TestimonialsSection.astro';
import PricingSection from '@components/sections/pricing/PricingSection.astro';
import FAQ from '@components/sections/misc/FAQ.astro';
import AnnouncementBanner from '@components/ui/banners/AnnouncementBanner.astro';
import heroImage from '@images/homepage_boat.png';
import faqs from '@data/faqs.json';
import features from '@data/features.json';
import pricing from '@data/pricing.json';
import featureImage from '@images/features-image.png';
import construction from '@images/marine_deck4.jpg';
import tools from '@images/process_1.jpg';
import dashboard from '@images/welds_3.jpg';
import { partnersData } from '@/data_files/constants';
---

<MainLayout>
  <AnnouncementBanner
    btnId="dismiss-button"
    title="Need marine welding, custom fabrication, or UltraDeck flooring for your boat?"
    btnTitle="Request a Quote"
    url="/contact"
  />

  <HeroSection
    title=`Custom <span class="text-orange-400 dark:text-orange-300">Boat Builds</span>, Marine Repairs, and UltraDeck Flooring`
    subTitle="Marine welding and fabrication shop specializing in custom boat builds, structural boat repairs, fabricated parts, fuel tanks, and UltraDeck marine flooring for everything from small skiffs to 40 ft ocean boats."
    primaryBtn="View Services"
    primaryBtnURL="/services"
    secondaryBtn="Request a Quote"
    secondaryBtnURL="/contact"
    src={heroImage}
    alt="Custom aluminum boat showcasing marine fabrication craftsmanship"
  />

  <ClientsSection
    title="Built for Boat Owners, Captains, and Working Crews"
    subTitle="Dependable marine fabrication for recreational, commercial, and offshore boats."
    partners={partnersData}
  />

  <FeaturesGeneral
    title="Marine Fabrication That Solves Real Boat Problems"
    subTitle="We build and repair hard-working aluminum boats with a practical, marine-first approach. Whether you need a custom hull, a repaired transom, a fabricated bracket, or a new fuel tank, our shop delivers durable work designed for life on the water."
    src={featureImage}
    alt="Marine fabrication and boat repair workmanship"
    features={features}
  />

  <FeaturesNavs
    title=`Three core services for <span class="text-orange-400 dark:text-orange-300">serious marine work</span>.`
    tabs={[
      {
        heading: 'Custom Boat Builds',
        content:
          'From compact skiffs to 40 ft ocean boats, we fabricate custom aluminum boats around the way you fish, work, and run offshore. Every build is tailored for strength, layout efficiency, and long-term durability.',
        svg: 'tools',
        src: tools,
        alt: 'Custom aluminum boat build in progress',
        first: true,
      },
      {
        heading: 'Boat Repairs & Fabricated Parts',
        content:
          'We handle the repair work boat owners actually need: cracked welds, structural damage, deck repairs, transoms, hatches, fabricated brackets, one-off parts, and marine fuel tanks built to fit your boat correctly.',
        svg: 'dashboard',
        src: dashboard,
        alt: 'Marine welding and custom boat repair work',
        second: true,
      },
      {
        heading: 'UltraDeck Marine Flooring',
        content:
          'Upgrade traction, comfort, and finish with professionally installed UltraDeck marine flooring. It is a clean, durable solution for fishing boats, workboats, and family boats that spend real time on the water.',
        svg: 'house',
        src: construction,
        alt: 'Boat deck with premium marine flooring',
      },
    ]}
  />

  <TestimonialsSection
    title="Built for Skiffs, Repairs, and Offshore Boats"
    subTitle="Our shop focuses on the work that matters most to boat owners: strong welds, clean fabrication, practical layouts, and marine-grade finishes that hold up in demanding conditions."
    testimonials={[
      {
        content:
          'We brought in a boat that needed repair work, fabricated parts, and a fuel tank solution that actually fit the hull. The result was clean, solid work that made the boat feel dependable again.',
        author: 'Boat Repair Client',
        role: 'Marine fabrication customer',
        avatarSrc:
          'https://images.unsplash.com/photo-1593104547489-5cfb3839a3b5?q=80&w=1453&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D8&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80',
      },
    ]}
    statistics={[
      {
        count: 'Skiffs',
        description:
          'Custom layouts and fabrication for small utility, hunting, and fishing boats',
      },
      {
        count: '40 ft',
        description:
          'Capability for larger custom aluminum boats and ocean-ready hulls',
      },
      {
        count: 'Fuel tanks',
        description:
          'Built alongside hatches, brackets, transoms, and made-to-fit marine parts',
      },
      {
        count: 'UltraDeck',
        description: 'Durable marine flooring installed for traction, comfort, and finish',
      },
    ]}
  />

  <PricingSection pricing={pricing} />

  <FAQ title="Frequently<br />asked questions" faqs={faqs} />

  <HeroSectionAlt
    title="Bring Your Boat Project to the Shop"
    subTitle="Whether you need a custom boat build, structural repair, fabricated parts, a new fuel tank, or UltraDeck marine flooring, we are ready to talk through the job and build the right solution."
    btnTitle="Contact the Shop"
    url="/contact"
  />
</MainLayout>
