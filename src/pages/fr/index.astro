---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import HeroSectionAlt from '@components/sections/landing/HeroSectionAlt.astro';
import ClientsSection from '@components/sections/landing/ClientsSection.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import FeaturesNavs from '@components/sections/features/FeaturesNavs.astro';
import TestimonialsSection from '@components/sections/testimonials/TestimonialsSection.astro';
import PricingSection from '@components/sections/pricing/PricingSection.astro';
import FAQ from '@components/sections/misc/FAQ.astro';
import AnnouncementBanner from '@components/ui/banners/AnnouncementBanner.astro';
import heroImage from '@images/homepage_boat.png';
import faqs from '@data/fr/faqs.json';
import features from '@data/fr/features.json';
import pricing from '@data/fr/pricing.json';
import featureImage from '@images/features-image.png';
import construction from '@images/marine_deck4.jpg';
import tools from '@images/process_1.jpg';
import dashboard from '@images/welds_3.jpg';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { partnersData } from '@/data_files/constants';
---

<MainLayout lang="fr">
  <AnnouncementBanner
    btnId="dismiss-button"
    title="Besoin de soudure marine, de fabrication sur mesure ou de plancher UltraDeck pour votre bateau ?"
    btnTitle="Demander un devis"
    url={getRelativeLocaleUrl('fr', 'contact')}
  />

  <HeroSection
    title=`Construction de <span class="text-orange-400 dark:text-orange-300">bateaux sur mesure</span>, reparations marines et planchers UltraDeck`
    subTitle="Atelier de soudure et de fabrication marine specialise dans la construction de bateaux sur mesure, les reparations structurelles, les pieces fabriquees, les reservoirs de carburant et les planchers marins UltraDeck pour les petites chaloupes jusqu'aux bateaux oceaniques de 40 pieds."
    primaryBtn="Voir les services"
    primaryBtnURL={getRelativeLocaleUrl('fr', 'services')}
    secondaryBtn="Demander un devis"
    secondaryBtnURL={getRelativeLocaleUrl('fr', 'contact')}
    src={heroImage}
    alt="Bateau en aluminium sur mesure illustrant le savoir-faire de fabrication marine"
  />

  <ClientsSection
    title="Pour les proprietaires de bateaux, capitaines et equipages"
    subTitle="Fabrication marine fiable pour bateaux de loisir, de travail et offshore."
    partners={partnersData}
  />

  <FeaturesGeneral
    title="Une fabrication marine qui resout les vrais problemes de bateaux"
    subTitle="Nous construisons et reparons des bateaux en aluminium avec une approche pratique et centree sur le milieu marin. Que vous ayez besoin d'une coque sur mesure, d'un tableau arriere repare, d'un support fabrique ou d'un nouveau reservoir, notre atelier livre un travail durable concu pour la vie sur l'eau."
    src={featureImage}
    alt="Travail de fabrication marine et de reparation de bateau"
    features={features}
  />

  <FeaturesNavs
    title=`Trois services principaux pour les <span class="text-orange-400 dark:text-orange-300">travaux marins serieux</span>.`
    tabs={[
      {
        heading: 'Construction de bateaux sur mesure',
        content:
          "Des petites chaloupes aux bateaux oceaniques de 40 pieds, nous fabriquons des bateaux en aluminium sur mesure selon votre facon de pecher, de travailler et de naviguer. Chaque projet est pense pour la solidite, l'efficacite de l'amenagement et la durabilite.",
        svg: 'tools',
        src: tools,
        alt: 'Construction dun bateau en aluminium sur mesure',
        first: true,
      },
      {
        heading: 'Reparations de bateaux et pieces fabriquees',
        content:
          "Nous realisons les reparations dont les proprietaires ont vraiment besoin : soudures fissurees, dommages structurels, ponts, tableaux arriere, trappes, supports, pieces uniques et reservoirs de carburant marins fabriques pour s'adapter correctement a votre bateau.",
        svg: 'dashboard',
        src: dashboard,
        alt: 'Soudure marine et reparation sur mesure de bateau',
        second: true,
      },
      {
        heading: 'Planchers marins UltraDeck',
        content:
          "Ameliorez l'adherence, le confort et la finition avec une installation professionnelle de plancher marin UltraDeck. C'est une solution propre et durable pour les bateaux de peche, les bateaux de travail et les bateaux familiaux qui passent de vraies heures sur l'eau.",
        svg: 'house',
        src: construction,
        alt: 'Pont de bateau avec plancher marin premium',
      },
    ]}
  />

  <TestimonialsSection
    title="Pour les chaloupes, les reparations et les bateaux offshore"
    subTitle="Notre atelier se concentre sur ce qui compte le plus pour les proprietaires de bateaux : des soudures solides, une fabrication propre, des amenagements pratiques et des finitions marines qui tiennent dans des conditions exigeantes."
    testimonials={[
      {
        content:
          "Nous avons apporte un bateau qui avait besoin de reparations, de pieces fabriquees et d'une solution de reservoir de carburant qui s'adaptait vraiment a la coque. Le resultat a ete un travail propre et solide qui a redonne confiance sur l'eau.",
        author: 'Client reparation bateau',
        role: 'Client fabrication marine',
        avatarSrc:
          'https://images.unsplash.com/photo-1593104547489-5cfb3839a3b5?q=80&w=1453&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D8&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80',
      },
    ]}
    statistics={[
      {
        count: 'Chaloupes',
        description:
          'Amenagements et fabrications sur mesure pour bateaux utilitaires, de chasse et de peche',
      },
      {
        count: '40 pi',
        description:
          'Capacite pour des bateaux en aluminium plus grands et des coques pretes pour le large',
      },
      {
        count: 'Reservoirs',
        description:
          'Construits avec trappes, supports, tableaux arriere et pieces marines sur mesure',
      },
      {
        count: 'UltraDeck',
        description: 'Plancher marin durable pour adherence, confort et finition',
      },
    ]}
  />

  <PricingSection pricing={pricing} />

  <FAQ title="Questions<br />frequemment posees" faqs={faqs} />

  <HeroSectionAlt
    title="Parlons de votre projet bateau"
    subTitle="Que vous ayez besoin d'une construction sur mesure, d'une reparation structurelle, de pieces fabriquees, d'un nouveau reservoir ou d'un plancher marin UltraDeck, nous sommes prets a discuter du bon plan pour votre bateau."
    btnTitle="Contacter latelier"
    url={getRelativeLocaleUrl('fr', 'contact')}
  />
</MainLayout>
